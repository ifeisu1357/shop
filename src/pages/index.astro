---
// WILDFLOWER STORE - 暫存頁面 (全螢幕照片版)
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WILDFLOWER STORE</title>
    <style>
        /* 清除所有預設邊距 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* 讓這張圖完美填滿整個螢幕，無黑邊 */
        body, html {
            width: 100%;
            height: 100vh;
            background-color: #000; /* 底色純黑 */
            
            /* 讀取你放在 public 裡面的照片 */
            background-image: url('/store-bg.jpg'); 
            
            /* cover 代表無情拉寬放大，絕對不留黑邊 */
            background-size: cover; 
            background-position: center; /* 圖片置中對齊 */
            background-repeat: no-repeat; /* 不重複拼接 */
            overflow: hidden; /* 隱藏滾動條 */
        }
    </style>
</head>
<body>
    </body>
</html>
