---
// WILDFLOWER STORE - 暫存頁面
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WILDFLOWER STORE</title>
    <style>
        /* 重置預設邊距 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000000; /* 純粹的黑 */
            color: #ffffff; /* 純粹的白 */
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            overflow: hidden;
        }

        h1 {
            /* 用 vw 讓字體大小跟著螢幕寬度縮放，保證在任何裝置都「超大」 */
            font-size: 10vw; 
            font-weight: 800;
            letter-spacing: -0.02em; /* 字距微縮，增加潮牌感 */
            text-align: center;
            line-height: 1;
            
            /* 電影感的淡入動畫 */
            opacity: 0;
            animation: fadeIn 3s ease-in-out forwards;
        }

        /* 手機版微調比例 */
        @media (max-width: 768px) {
            h1 {
                font-size: 15vw; 
            }
        }

        /* 定義淡入動畫 */
        @keyframes fadeIn {
            0% {
                opacity: 0;
                transform: scale(0.98); /* 微微放大的效果 */
            }
            100% {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</head>
<body>
    <h1>BE HERE SOON</h1>
</body>
</html>
